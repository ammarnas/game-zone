@model CreateGameFormViewModel

@{
    ViewData["Title"] = "Create Game";
}

<h5>
    <i class="bi bi-plus-square"></i>
    Create a new game
</h5>

<form asp-controller="Games" enctype="multipart/form-data">
    <div class="row">
        <div class="col-md-6">
            <div>
                <label asp-for="Name" class="form-label mt-4"></label>
                <input type="text" class="form-control" asp-for="Name" placeholder="Enter name">
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="CategoryId" class="form-label mt-4"></label>
                    <select class="form-select" asp-for="CategoryId" asp-items="Model.Categories">
                        <option>select a category</option>
                    </select>
                <span asp-validation-for="CategoryId" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="SelectedDevices" class="form-label mt-4"></label>
                <select class="form-select" asp-for="SelectedDevices" asp-items="Model.Devices" multiple>
                    <option>select supported devices</option>
                </select>
                <span asp-validation-for="SelectedDevices" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="Description" class="form-label mt-4"></label>
                <textarea class="form-control" asp-for="Description" placeholder="Enter description"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="Cover" class="form-label mt-4"></label>
                <input type="file" class="form-control" asp-for="Cover">
                <span asp-validation-for="Cover" class="text-danger"></span>
                <small asp-for="Cover" class="form-text text-muted d-block">
                    Supported formats: @FileSettings.AllowedImageExtensions. Max size: @(FileSettings.MaxImageSizeInMB)MB.
                </small>
            </div>
            <button type="submit" class="btn btn-light text-black mt-4">Save</button>
        </div>
        <div class="col-md-6"></div>
    </div>
</form>